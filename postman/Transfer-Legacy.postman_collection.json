        { "name": "StepUp Request", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"user_id\": \"00000000-0000-0000-0000-000000000001\",\n  \"action\": \"policy_update\",\n  \"challenge_type\": \"totp\"\n}" }, "url": "{{baseUrl}}/v1/auth/stepup/request" } },
