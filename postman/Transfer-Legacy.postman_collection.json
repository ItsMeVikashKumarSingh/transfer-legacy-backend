    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Init",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-idempotency-key", "value": "{{xIdempotencyKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"00000000-0000-0000-0000-000000000001\",\n  \"registration_request\": \"base64-registration-request\",\n  \"credential_identifier\": \"user@example.com\"\n}"
            },
            "url": "{{baseUrl}}/v1/auth/register/init"
          }
        },
        {
          "name": "Register Finish (AEAD)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-seq", "value": "{{xSeq}}" },
              { "key": "x-timestamp", "value": "{{xTimestamp}}" },
              { "key": "x-device-id", "value": "{{deviceId}}" },
              { "key": "x-idempotency-key", "value": "{{xIdempotencyKey}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"nonce\": \"{{aeadNonce}}\",\n  \"ciphertext\": \"{{aeadCiphertext}}\"\n}" },
            "url": "{{baseUrl}}/v1/auth/register/finish"
          }
        },
        {
          "name": "Login Init",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-idempotency-key", "value": "{{xIdempotencyKey}}" }
