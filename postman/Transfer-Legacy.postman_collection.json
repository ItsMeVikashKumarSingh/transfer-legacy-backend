        { "name": "WebAuthn Authenticate Start", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"user_id\": \"00000000-0000-0000-0000-000000000001\"\n}" }, "url": "{{baseUrl}}/v1/auth/mfa/webauthn/authenticate/start" } },
