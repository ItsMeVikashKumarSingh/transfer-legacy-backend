            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"00000000-0000-0000-0000-000000000001\",\n  \"credential_request\": \"base64-credential-request\"\n}"
            },
            "url": "{{baseUrl}}/v1/auth/login/init"
          }
        },
        {
          "name": "Login Finish (AEAD)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-seq", "value": "{{xSeq}}" },
              { "key": "x-timestamp", "value": "{{xTimestamp}}" },
              { "key": "x-device-id", "value": "{{deviceId}}" },
