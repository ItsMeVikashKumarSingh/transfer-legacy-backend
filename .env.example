# Redis (rate limiting, idempotency, OPAQUE state)
# Example: redis://:password@127.0.0.1:6379
REDIS_URL=

# OpenBao
OPENBAO_ADDR=
OPENBAO_TOKEN=

# Brevo
BREVO_API_KEY=
