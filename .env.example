# Example environment variables (no real values)
# Each entry includes purpose + example format.

# ==============================================================================
# 1. CORE SERVER CONFIGURATION (Common to both modes)
# ==============================================================================
TL_BIND_ADDR=0.0.0.0
TL_PORT=8080
TL_ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com
TL_APP_URL=https://app.example.com
TL_BRAND_NAME="Transfer Legacy"
TL_SERVER_ID=local-dev
TL_INTERNAL_API_TOKEN=change-me-internal-token

# ==============================================================================
# 2. DEPLOYMENT MODE TOGGLE
# ==============================================================================
# Set to 'true' for Vercel/Serverless. Set to 'false' for VPS/Enterprise.
TL_SERVERLESS=true

# ==============================================================================
# 3. MODE-SPECIFIC CONFIGURATION
# ==============================================================================

# --- A. SERVERLESS MODE ONLY (TL_SERVERLESS=true) ---
# Ed25519 private key (Base64) for stateless signing.
TL_SERVER_PRIVATE_KEY_B64=base64-encoded-32-byte-private-key
# Secret to protect /v1/jobs/* webhook endpoints.
TL_CRON_SECRET=secure-random-cron-secret

# --- B. ENTERPRISE MODE ONLY (TL_SERVERLESS=false) ---
# OpenBao base URL (internal).
OPENBAO_ADDR=http://127.0.0.1:8200
# OpenBao token for transit/KV access.
OPENBAO_TOKEN=hvs.xxxxxxxxxxxxxxxxxxxx
# OpenBao KV v2 path for backup key retrieval.
OPENBAO_BACKUP_KEY_PATH=secret/data/transfer-legacy/backup
# OpenBao field name that contains backup key material.
OPENBAO_BACKUP_KEY_FIELD=key

# ==============================================================================
# 4. INFRASTRUCTURE & SECRETS (Required in both modes)
# ==============================================================================

# Supabase Auth (HTTP API)
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SECRET_KEY=sb_secret_service_role_key
SUPABASE_PUBLISHABLE_KEY=sb_publishable_anon_key

# Postgres (SQL access)
# NOTE: For Serverless, ALWAYS use the pooler URL (port 6543)
DATABASE_URL=postgresql://postgres.<project>:<password>@<region>.pooler.supabase.com:6543/postgres

# Redis (Caching & Rate Limiting)
# NOTE: For Serverless, use an external provider like Upstash
REDIS_URL=rediss://default:password@region.upstash.io:6379

# Resend (Email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL="Transfer Legacy <waitlist@transferlegacy.com>"
RESEND_FROM_NAME="Transfer Legacy"
TEST_REAL_EMAIL=false

# Backblaze B2 (Storage)
BACKBLAZE_B2_KEY_ID=key-id
BACKBLAZE_B2_APP_KEY=app-key
BACKBLAZE_B2_BUCKET_NAME=tl-user-files-prod
BACKBLAZE_B2_PUBLIC_ASSETS_BUCKET_NAME=tl-public-assets-prod
BACKBLAZE_B2_AUDIT_BUCKET_NAME=tl-audit-anchors-prod
BACKBLAZE_B2_BACKUP_BUCKET_NAME=tl-db-backups-prod
BACKBLAZE_B2_ENDPOINT_URL=s3.<region>.backblazeb2.com

# Backup key for pg_dump encryption
BACKUP_KEY=base64-encoded-backup-encryption-key

# Observability
SENTRY_DSN=https://public@sentry.example.com/1
POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxx
POSTHOG_HOST=https://app.posthog.com

# Application Internal Secrets
SERVER_HMAC_SECRET=base64-encoded-hmac-secret
SERVER_AEAD_KEY=base64url-no-pad-32-byte-key
JWT_SECRET=jwt-signing-secret
OPAQUE_SERVER_SETUP=base64-opaque-setup-blob
