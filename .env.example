# Example environment variables (no real values)
# Each entry includes purpose + example format.

# Core server
# Bind address for the API listener.
TL_BIND_ADDR=0.0.0.0
# Port for the API listener.
TL_PORT=8080
# Comma-separated allowed origins for CORS.
TL_ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com
# Public app base URL used in email templates and links.
TL_APP_URL=https://app.example.com
# Brand name used in email templates.
TL_BRAND_NAME=Transfer Legacy
# Stable server identifier for audit anchors.
TL_SERVER_ID=prod-eu-1
# Shared token required to access /metrics, /v1/openapi.json, /v1/docs.
TL_INTERNAL_API_TOKEN=change-me-internal-token

# Supabase Auth (HTTP API)
# Supabase project URL (auth + REST).
SUPABASE_URL=https://<project>.supabase.co
# Supabase secret key (server-side privileged operations).
SUPABASE_SECRET_KEY=super-secret-service-role-key
# Supabase publishable key (public client key for limited access).
SUPABASE_PUBLISHABLE_KEY=public-publishable-key

# Postgres (SQL access via sqlx)
# Local dev (docker compose): postgresql://postgres:postgres@db:5432/transfer_legacy
# Supabase examples:
# - Direct:  postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
# - Pooler:  postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@db:5432/transfer_legacy

# Valkey (Redis-compatible) (rate limiting, idempotency, OPAQUE state)
# Example (Upstash): rediss://default:<password>@<host>:<port>
REDIS_URL=rediss://default:password@redis.example.com:6379

# OpenBao
# OpenBao base URL (internal).
OPENBAO_ADDR=http://127.0.0.1:8200
# OpenBao token for transit/KV access.
OPENBAO_TOKEN=bao-token
# OpenBao KV v2 path for backup encryption key retrieval.
OPENBAO_BACKUP_KEY_PATH=secret/data/transfer-legacy/backup
# OpenBao field name that contains backup key material.
OPENBAO_BACKUP_KEY_FIELD=key

# Brevo (transactional email)
# Brevo API key for template sends.
BREVO_API_KEY=brevo-api-key
# Brevo SMTP password (Supabase Auth email).
BREVO_SMTP_PASSWORD=brevo-smtp-password
# Template IDs for transactional emails.
BREVO_INVITE_TEMPLATE_ID=1000001
BREVO_OWNER_REMINDER_EARLY_TEMPLATE_ID=1000002
BREVO_OWNER_REMINDER_URGENT_TEMPLATE_ID=1000003
BREVO_OWNER_REMINDER_DAILY_TEMPLATE_ID=1000004
BREVO_BENEFICIARY_CLAIM_AVAILABLE_TEMPLATE_ID=1000005
BREVO_APPROVER_ATTESTATION_REQUEST_TEMPLATE_ID=1000006
BREVO_CONFLICT_HOLD_NOTICE_TEMPLATE_ID=1000007
BREVO_RELEASE_READY_TEMPLATE_ID=1000008

# Backblaze B2 (S3-compatible)
# B2 key ID and application key for S3 access.
BACKBLAZE_B2_KEY_ID=key-id
BACKBLAZE_B2_APP_KEY=app-key
# Bucket name for encrypted user uploads.
BACKBLAZE_B2_BUCKET_NAME=tl-user-files-prod
# Bucket name for daily audit anchors.
BACKBLAZE_B2_AUDIT_BUCKET_NAME=tl-audit-anchors-prod
# Bucket name for database backups.
BACKBLAZE_B2_BACKUP_BUCKET_NAME=tl-db-backups-prod
# B2 S3 endpoint URL.
BACKBLAZE_B2_ENDPOINT_URL=https://s3.us-west-000.backblazeb2.com

# Backup encryption key (used to encrypt backups).
BACKUP_KEY=base64-encoded-key

# Observability
# Sentry DSN for error reporting.
SENTRY_DSN=https://public@sentry.example.com/1
# PostHog project API key.
POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxx
# PostHog host (cloud or self-hosted).
POSTHOG_HOST=https://app.posthog.com

# App secrets
# HMAC secret for invite token verification.
SERVER_HMAC_SECRET=base64-encoded-hmac-secret
# AEAD key for app-layer transport encryption (base64url-no-pad, 32 bytes).
SERVER_AEAD_KEY=base64url-no-pad-32-byte-key
# JWT signing secret for session tokens.
JWT_SECRET=jwt-signing-secret
# OPAQUE server setup blob (base64).
OPAQUE_SERVER_SETUP=base64-opaque-setup
